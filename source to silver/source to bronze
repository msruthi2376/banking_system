# 6️⃣ Execution: Read → Write to Bronze
# =====================================================

try:
    # Get bronze table schema to match columns
    bronze_schema = spark.table(bronze_table_fqn).schema
    bronze_columns = [field.name for field in bronze_schema.fields if field.name != "insert_timestamp"]
    
    # Select and transform source columns to match bronze schema
    source_df = source_df.select(*[col(c) if c in source_df.columns else lit(None).alias(c) for c in bronze_columns]) \
                         .withColumn("updated_at", col("updated_at").cast("string")) \
                         .withColumn("insert_timestamp", current_timestamp())
    
    records_count = source_df.count()
    print(f"Extracted {records_count} new records.")

    # Write to Bronze (Delta)
    source_df.write.format("delta").mode("append").saveAsTable(bronze_table_fqn)

    # Update Audit to SUCCESS
    end_time = spark.sql("SELECT current_timestamp()").collect()[0][0]
    spark.sql(f"""
        UPDATE main.metadata.pipeline_runs 
        SET end_time = TIMESTAMP('{end_time}'), status = 'SUCCESS', number_of_records = {records_count}
        WHERE run_id = '{run_id}' AND table_id = {table_id}
    """)
    
    # Update Watermark (Simulating progression)
    if records_count > 0:
        new_watermark = source_df.agg({"updated_at": "max"}).collect()[0][0]
        spark.sql(f"DELETE FROM main.metadata.table_watermarks WHERE table_id = {table_id}")
        spark.sql(f"INSERT INTO main.metadata.table_watermarks VALUES ({table_id}, '{new_watermark}')")

    print("✅ Process completed successfully.")

except Exception as e:
    error_msg = str(e)[:500].replace("'", "")
    spark.sql(f"""
        UPDATE main.metadata.pipeline_runs 
        SET status = 'FAILED', error_message = '{error_msg}'
        WHERE run_id = '{run_id}' AND table_id = {table_id}
    """)
    raise e
