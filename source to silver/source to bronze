def get_source_data(table_id, watermark_val, watermark_col):
    """Reads data from CSV files in banking_project."""
    
    # Get source table info from metadata
    metadata_df = spark.sql(f"SELECT source_table FROM banking.metadata.tables WHERE table_id = {table_id}")
    source_table = metadata_df.first()["source_table"]
    
    # Handle file name mismatch (customers -> customer.csv)
    file_mapping = {
        "customers": "customer.csv",
        "accounts": "accounts.csv",
        "transactions": "transaction.csv",
        "branches": "branches.csv"
    }
    csv_file = file_mapping.get(source_table, f"{source_table}.csv")
    
    # Construct CSV file path using the actual file name
    csv_path = f"file:/Workspace/Users/msruthi.2376@gmail.com/metapipeline/banking_project/00_csv files/{csv_file}"
    
    print(f"Reading from: {csv_path}")
    
    # Define schema based on source table type
    # accounts.csv has no header row - define explicit schema
    if source_table == "accounts":
        schema = StructType([
            StructField("account_id", StringType(), True),
            StructField("customer_id", IntegerType(), True),
            StructField("branch_id", StringType(), True),
            StructField("account_type", StringType(), True),
            StructField("balance", StringType(), True),
            StructField("currency", StringType(), True),
            StructField("status", StringType(), True),
            StructField("created_date", StringType(), True),
            StructField("created_at", StringType(), True),
            StructField("updated_at", StringType(), True)
        ])
        df = spark.read.format("csv").option("header", "false").schema(schema).load(csv_path)
    else:
        # For other tables, assume they have headers
        df = spark.read.format("csv").option("header", "true").option("inferSchema", "true").load(csv_path)
    
    # Apply watermark filter if watermark column exists and has data
    if watermark_col and watermark_col in df.columns:
        print(f"Applying watermark filter: {watermark_col} > '{watermark_val}'")
        # Convert string timestamp column to timestamp type for comparison
        df = df.withColumn(watermark_col, to_timestamp(col(watermark_col))).filter(col(watermark_col) > lit(watermark_val))
    else:
        print(f"No watermark filtering applied (column: {watermark_col})")
    
    return df

# Read source data with watermark filtering
source_df = get_source_data(table_id, last_watermark, watermark_column)

