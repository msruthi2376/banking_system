%sql
-- Create dim_date
CREATE OR REPLACE TABLE banking.gold.dim_date (
  date_sk BIGINT NOT NULL,
  date DATE NOT NULL,
  day_of_week STRING,
  day_of_month INT,
  day_of_year INT,
  week_of_year INT,
  month INT,
  month_name STRING,
  quarter INT,
  year INT,
  is_weekend BOOLEAN,
  is_holiday BOOLEAN,
  fiscal_year INT,
  fiscal_quarter INT,
  PRIMARY KEY (date_sk)
) USING DELTA;

from pyspark.sql import functions as F
from datetime import datetime, timedelta

# Generate 10 years of dates (2020-2030 as example range)
start_date = datetime(2020, 1, 1)
end_date = datetime(2030, 12, 31)

# Create date range
date_list = []
current_date = start_date
while current_date <= end_date:
    date_list.append((current_date,))
    current_date += timedelta(days=1)

# Create DataFrame
df_dates = spark.createDataFrame(date_list, ["date"])

# Add all date dimension attributes
df_dim_date = df_dates.select(
    F.date_format(F.col("date"), "yyyyMMdd").cast("bigint").alias("date_sk"),
    F.to_date(F.col("date")).alias("date"),
    F.date_format(F.col("date"), "EEEE").alias("day_of_week"),
    F.dayofmonth(F.col("date")).alias("day_of_month"),
    F.dayofyear(F.col("date")).alias("day_of_year"),
    F.weekofyear(F.col("date")).alias("week_of_year"),
    F.month(F.col("date")).alias("month"),
    F.date_format(F.col("date"), "MMMM").alias("month_name"),
    F.quarter(F.col("date")).alias("quarter"),
    F.year(F.col("date")).alias("year"),
    F.when(F.dayofweek(F.col("date")).isin([1, 7]), True).otherwise(False).alias("is_weekend"),  # 1=Sunday, 7=Saturday
    F.lit(False).alias("is_holiday"),  # Default to False, can be updated later
    F.year(F.col("date")).alias("fiscal_year"),  # Assuming fiscal year = calendar year
    F.quarter(F.col("date")).alias("fiscal_quarter")  # Assuming fiscal quarter = calendar quarter
)

# Insert into dim_date table
df_dim_date.write.mode("overwrite").saveAsTable("banking.gold.dim_date")

# Verify the load
record_count = spark.table("banking.gold.dim_date").count()
print(f"✅ Successfully populated dim_date with {record_count:,} records")
print(f"📅 Date range: {start_date.date()} to {end_date.date()}")

%sql
-- Sample dim_date records
SELECT 
  date_sk,
  date,
  day_of_week,
  month_name,
  quarter,
  year,
  is_weekend,
  fiscal_year,
  fiscal_quarter
FROM banking.gold.dim_date
WHERE year IN (2020, 2025, 2030)
  AND month IN (1, 6, 12)
ORDER BY date
LIMIT 15;
