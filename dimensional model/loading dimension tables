%sql
-- Populate dim_branch from silver.branches (Type 1 SCD - overwrite on changes)
MERGE INTO banking.gold.dim_branch AS tgt
USING (
  SELECT 
    branch_code,
    branch_name,
    city,
    state,
    CASE 
      WHEN state IN ('NY', 'NJ', 'CT', 'PA', 'MA') THEN 'Northeast'
      WHEN state IN ('CA', 'WA', 'OR', 'NV', 'AZ') THEN 'West'
      WHEN state IN ('TX', 'FL', 'GA', 'NC', 'VA') THEN 'South'
      WHEN state IN ('IL', 'OH', 'MI', 'IN', 'WI') THEN 'Midwest'
      ELSE 'Other'
    END AS region,
    opened_date,
    TRUE AS is_active,
    CURRENT_TIMESTAMP() AS insert_timestamp,
    CURRENT_TIMESTAMP() AS update_timestamp
  FROM banking.silver.branches
) AS src
ON tgt.branch_code = src.branch_code
WHEN MATCHED THEN
  UPDATE SET
    tgt.branch_name = src.branch_name,
    tgt.city = src.city,
    tgt.state = src.state,
    tgt.region = src.region,
    tgt.opened_date = src.opened_date,
    tgt.is_active = src.is_active,
    tgt.update_timestamp = src.update_timestamp
WHEN NOT MATCHED THEN
  INSERT (
    branch_code, branch_name, city, state, region, 
    opened_date, is_active, insert_timestamp, update_timestamp
  )
  VALUES (
    src.branch_code, src.branch_name, src.city, src.state, src.region,
    src.opened_date, src.is_active, src.insert_timestamp, src.update_timestamp
  );

